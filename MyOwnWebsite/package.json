    "@visactor/vue-vtable": "^1.22.2",
    "axios": "^1.7.0",
    "boneyard-vue": "^1.0.2",
    "dayjs": "^1.11.20",
    "echarts": "^6.0.0",
    "lodash": "^4.18.1",
    "three": "^0.183.0",
    "typeit": "^8.8.7",
    "vfit": "^2.0.2",
    "vicons": "^0.0.1",
    "vue": "^3.5.30",
    "vue-request": "^2.0.4",
    "vue3-border-beam": "^0.0.2"
